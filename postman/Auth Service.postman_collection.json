{
  "info": {
    "_postman_id": "d4f4d5c7-24ea-4f79-9f62-c94ee0b03ef6",
    "name": "Auth Service",
    "description": "Collection for auth-service endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secure123\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/auth/register",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "description": "Register a user for local testing."
      },
      "response": []
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "const token = json.token || json.accessToken || json.jwt || json.authToken;",
              "",
              "pm.test(\"JWT token returned\", function () {",
              "  pm.expect(token).to.exist;",
              "});",
              "",
              "if (token) {",
              "  pm.environment.set(\"authToken\", token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secure123\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/auth/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Authenticate and store JWT in authToken."
      },
      "response": []
    },
    {
      "name": "Get Current User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{authBaseUrl}}/auth/me",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        },
        "description": "Fetch current user details with the saved JWT."
      },
      "response": []
    }
  ]
}
